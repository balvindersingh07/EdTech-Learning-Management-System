# Prisma SQLite file lives at prisma/dev.db (see prisma/schema.prisma). Copy secrets only below.
# After clone: npm run db:generate && npm run db:migrate
# Standalone API (`node backend/src/server.js`) persists the full LMS graph into table `AppStateSnapshot`.

# Static bootstrap admin (Node API only — used when running backend / Vite embedded API)
# ADMIN_EMAIL=admin@lms.local
# ADMIN_PASSWORD=Admin@123

# Frontend API base (axios). Dev default `/api` = Vite embeds Express on same origin.
# Vercel / static hosting: set to your deployed API origin + `/api`, e.g.
# VITE_API_URL=https://your-api.onrender.com/api
# VITE_API_URL=/api

# Backend JWT secret when running `node backend/src/server.js` standalone
# JWT_SECRET=change-me-in-production
