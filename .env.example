# Optional: override API base (default /api — same origin with Vite-embedded API in dev)
# VITE_API_URL=/api

# Microsoft Entra ID (Azure AD) — optional SPA sign-in
# Register a single-page app in Azure Portal, add redirect URI = http://localhost:5173 (or your origin)
# VITE_AZURE_CLIENT_ID=
# VITE_AZURE_TENANT_ID=
# VITE_AZURE_REDIRECT_URI=http://localhost:5173

# Backend JWT secret when running `node backend/src/server.js` standalone
# JWT_SECRET=change-me-in-production
