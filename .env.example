# Prisma SQLite — required for migrate/generate (see prisma/schema.prisma)
DATABASE_URL="file:./prisma/dev.db"
# Azure App Service example (persistent under /home): file:./prisma/prod.db
# After clone: npm install (runs postinstall prisma generate) && npm run db:migrate
# Standalone API (`node backend/src/server.js`) persists the full LMS graph into table `AppStateSnapshot`.

# Static bootstrap admin (Node API only — used when running backend / Vite embedded API)
# ADMIN_EMAIL=admin@lms.local
# ADMIN_PASSWORD=Admin@123

# Frontend API base (axios). Local dev: MUST be /api (Vite embeds Express).
# Vercel dashboard: set full URL https://your-api.../api (not needed in .env for local).

# Backend JWT secret when running `node backend/src/server.js` standalone
# JWT_SECRET=change-me-in-production
