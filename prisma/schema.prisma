// EdTech LMS — SQLite. Snapshot row persists full in-memory LMS state for standalone API.
// Generate: npm run db:generate — Migrate: npm run db:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Kept for future normalized user queries; runtime source of truth for standalone server is AppStateSnapshot when enabled.
model User {
  id             String   @id
  email          String   @unique
  name           String
  password       String
  role           String
  accountStatus  String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Full LMS store JSON — courses, users, enrollments, etc. (see InMemoryStore.exportState).
model AppStateSnapshot {
  id        Int      @id @default(1)
  payload   String
  updatedAt DateTime @updatedAt
}
